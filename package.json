      "types": "./encoding.d.ts"
    },
    "./url": {
      "types": "./url.d.ts"
    },
    "./urlpattern": {
      "types": "./urlpattern.d.ts"
    },
    "./webcrypto": {
      "types": "./webcrypto.d.ts"
    },
    "./hr-time": {
      "types": "./hr-time.d.ts"
